#!/bin/bash

BIN=/usr/lib/chromium/chromium

# Cleanup
if ! pgrep chromium > /dev/null;then
  rm -f $HOME/.config/chromium/Singleton*
fi

# Wayland check
if pgrep labwc > /dev/null 2>&1; then
  WAYLAND="--ozone-platform=wayland"
fi

${BIN} \
  --no-sandbox \
  --test-type \
  --user-data-dir \
  ${WAYLAND} \
   "$@" > /dev/null 2>&1
